{
  "name": "professor-pixel-programming-palace",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "bufferutil", "esbuild", "msw"]
  },
  "scripts": {
    "dev": "pnpm --filter @professor-pixel/web dev",
    "dev:mobile": "pnpm --filter @professor-pixel/mobile start",
    "build": "pnpm -r build",
    "check": "pnpm -r check && tsc",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "pnpm -r test",
    "clean": "pnpm -r exec rm -rf dist node_modules && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jszip": "^3.4.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^27.0.0",
    "msw": "^2.11.2",
    "supertest": "^7.1.4",
    "vitest": "^3.2.4"
  }
}
